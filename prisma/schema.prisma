  wrntyExpDate   DateTime?
  remarks        String?

  @@index([tenantId])
}

model StationeryStock {
  id       String   @id @default(cuid())
  tenantId String
  firmId   String
  type     String // INWARD | ISSUE
  date     DateTime
  bookNo   String?
  fromNo   Int?
  toNo     Int?
  issuedTo String?
  remarks  String?

  createdAt DateTime @default(now())

  @@index([tenantId])
}

// ============ TRACKING ============

model TrackingEvent {
  id       String   @id @default(cuid())
  tenantId String
  lrId     String?
  lr       Lr?      @relation(fields: [lrId], references: [id])
  lrNo     String?
  grNo     String?
  date     DateTime
  location String?
  status   String? // e.g. IN_TRANSIT | DELIVERED
  remarks  String?

  createdAt DateTime @default(now())

  @@index([tenantId, lrId])
}

// ============ SAVED FILTERS ============

model SavedFilter {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  screen   String
  name     String
  params   Json

  @@unique([userId, screen, name])
  @@index([tenantId])
}
