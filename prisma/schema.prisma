  grandTotal    Decimal     @default(0) @db.Decimal(14, 2)
  netTotal      Decimal     @default(0) @db.Decimal(14, 2)
  advance       Decimal     @default(0) @db.Decimal(14, 2)
  balance       Decimal     @default(0) @db.Decimal(14, 2)
  totalWt       Decimal     @default(0) @db.Decimal(12, 3)

