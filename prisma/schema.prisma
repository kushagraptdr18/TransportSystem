generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============ ENUMS ============

enum Role {
  OWNER
  ADMIN
  OPERATOR
  ACCOUNTANT
  VIEWER
}

enum LedgerGroup {
  BANK
  CASH
  CONSIGNEE_CONSIGNOR
  DRIVER
  EXPENSE
  INCOME
  OFFICE
  OWNER_BROKER
  STAFF
  SUPPLIERS
}

enum LrType {
  TO_PAY
  TBB
  PAID
  FOC
  CANCELLED
  PAPER_CHANGE
}

enum LrStatus {
  PENDING
  ON_CHALAN
  ARRIVED
  DELIVERED
  BILLED
}

enum RateBasis {
  QTY
  ACTUAL_WT
  CHARGE_WT
  FIXED
}

enum VoucherType {
  RECEIPT
  PAYMENT
  CONTRA
}

enum VoucherEntryType {
  CASH
  BANK
  CONTRA
}

enum ModuleLink {
  BILLING
  LORRY_HIRE
  BROKER_ENTRY
  FREIGHT_CHALLAN
  CASH_MEMO
  GST_BILLING
  LR_ENTRY
  OTHERS
}

enum AdvanceType {
  CASH
  BANK
  DIESEL
  TOLL
  TYRE
  SPARE_PARTS
  REPAIR
  OTHER
}

enum PodSourceType {
  BOOKING
  OUTWARD_CROSSING
  CROSSING_CHALLAN
  GATE_PASS
  BROKER_SLIP
}

enum DeliveryType {
  GATE_PASS
  CASH_MEMO
}

enum CashCredit {
  CASH
  CREDIT
}

enum LoadingChalanType {
  DIRECT
  CROSSING
}

enum InvoiceKind {
  PART_TRUCK
  FULL_TRUCK
  MANUAL
  GST
}

enum TdsMode {
  TDS_APPLICABLE
  DECLARATION
}

enum TripLeg {
  GOING
  RETURN
}

enum EntrySide {
  DEBIT
  CREDIT
}

enum DocNumberType {
  LR
  CHALAN
  LOADING_CHALAN
  ARRIVAL
  DELIVERY
  CROSSING
  OUTWARD_CROSSING
  HIRE_SLIP
  SUMMARY
  VOUCHER_RECEIPT
  VOUCHER_PAYMENT
  VOUCHER_CONTRA
  POD
  BROKER_SLIP
  BROKER_BILL
  TRIP
  JOB_ENTRY
  PURCHASE
  CASH_REPORT
}

// ============ PLATFORM ============

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  firms Firm[]
}

model Firm {
  id                 String   @id @default(cuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  name               String
  alias              String?
  address1           String?
  address2           String?
  stateId            String?
  cityId             String?
  phone              String?
  mobile             String?
  email              String?
  website            String?
  gstin              String?
  pan                String?
  cin                String?
  msmeNo             String?
  jurisdiction       String?
  cgstPct            Decimal  @default(0) @db.Decimal(5, 2)
  sgstPct            Decimal  @default(0) @db.Decimal(5, 2)
  igstPct            Decimal  @default(0) @db.Decimal(5, 2)
  bankName           String?
  bankAccount        String?
  bankBranch         String?
  bankIfsc           String?
  logoPath           String?
  sealPath           String?
  smtpHost           String?
  smtpUser           String?
  smtpPass           String?
  defaultBankPartyId String?
  defaultTdsPct      Decimal  @default(1) @db.Decimal(5, 2)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  financialYears FinancialYear[]
  userFirms      UserFirm[]

  @@index([tenantId])
}

model FinancialYear {
  id        String   @id @default(cuid())
  tenantId  String
  firmId    String
  firm      Firm     @relation(fields: [firmId], references: [id])
  label     String // e.g. "2026-2027"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)

  @@unique([firmId, label])
  @@index([tenantId])
}

model User {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  username      String
  passwordHash  String
  role          Role     @default(OPERATOR)
  signaturePath String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userFirms   UserFirm[]
  permissions UserPermission[]
  auditLogs   AuditLog[]

  @@unique([tenantId, username])
  @@index([tenantId])
}

model UserFirm {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id])

  @@unique([userId, firmId])
}

model UserPermission {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  module    String // e.g. "lr", "chalan", "billing", "masters", "reports", "accounts"
  canView   Boolean @default(true)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)
  canPrint  Boolean @default(true)
  canExport Boolean @default(true)

  @@unique([userId, module])
}

model DocumentSequence {
  id       String        @id @default(cuid())
  tenantId String
  firmId   String
  fyId     String
  docType  DocNumberType
  next     Int           @default(1)
  prefix   String        @default("")

  @@unique([firmId, fyId, docType])
  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  firmId    String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  entity    String
  entityId  String
  action    String // CREATE | UPDATE | DELETE | PRINT | LOGIN
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, entity, entityId])
}

// ============ MASTERS ============

model State {
  id       String @id @default(cuid())
  tenantId String
  name     String
  gstCode  String @default("")
  cities   City[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model City {
  id         String  @id @default(cuid())
  tenantId   String
  stateId    String
  state      State   @relation(fields: [stateId], references: [id])
  name       String
  district   String?
  pincode    String?
  stdCode    String?
  officeType String?

  @@unique([tenantId, name, stateId])
  @@index([tenantId])
}

model Party {
  id                 String      @id @default(cuid())
  tenantId           String
  ledgerGroup        LedgerGroup
  name               String
  alias              String?
  address1           String?
  address2           String?
  stateId            String?
  cityId             String?
  gstin              String?
  pan                String?
  aadhar             String?
  iecNo              String?
  rcNo               String?
  licenseNo          String?
  ownerName          String?
  phone              String?
  mobile             String?
  email              String?
  arnNo              String?
  vendorCode         String?
  openingBalance     Decimal     @default(0) @db.Decimal(14, 2)
  openingSide        EntrySide   @default(DEBIT)
  // broker TDS handling
  tdsMode            TdsMode?
  bankName           String?
  bankAccount        String?
  bankBranch         String?
  bankIfsc           String?
  panDocPath         String?
  declarationDocPath String?
  aadharDocPath      String?
  gstDocPath         String?
  photoPath          String?
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  vehicles Vehicle[]

  @@unique([tenantId, name, ledgerGroup])
  @@index([tenantId, ledgerGroup])
}

model AccountHead {
  id       String @id @default(cuid())
  tenantId String
  name     String
  kind     String // INCOME | EXPENSE

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ProductGroup {
  id       String    @id @default(cuid())
  tenantId String
  name     String
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Product {
  id        String       @id @default(cuid())
  tenantId  String
  groupId   String
  group     ProductGroup @relation(fields: [groupId], references: [id])
  name      String
  unit      String? // default unit, e.g. MT
  type      String?
  hsnCode   String?
  gstPct    Decimal      @default(0) @db.Decimal(5, 2)
  className String?
  division  String?
  leadTime  String?

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Unit {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  value    Decimal @default(1) @db.Decimal(12, 4)

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Vehicle {
  id               String   @id @default(cuid())
  tenantId         String
  number           String
  ownerId          String?
  owner            Party?   @relation(fields: [ownerId], references: [id])
  isOwn            Boolean  @default(false)
  ownerNames       String? // owned vehicles: one or more owner names, comma-separated
  chassisNo        String?
  engineNo         String?
  vehicleType      String?
  permitNo         String?
  insuranceNo      String?
  rcDocPath        String?
  fitnessDocPath   String?
  insuranceDocPath String?
  permitDocPath    String?
  stateTaxDocPath  String?
  pucDocPath       String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  @@unique([tenantId, number])
  @@index([tenantId])
}

model RateMaster {
  id              String    @id @default(cuid())
  tenantId        String
  partyId         String
  productId       String?
  sourceCityId    String
  destCityId      String
  rate            Decimal   @default(0) @db.Decimal(12, 2)
  rateBasis       RateBasis @default(CHARGE_WT)
  hamali          Decimal   @default(0) @db.Decimal(12, 2)
  hamaliBasis     RateBasis @default(FIXED)
  preBhada        Decimal   @default(0) @db.Decimal(12, 2)
  preBhadaBasis   RateBasis @default(FIXED)
  dCharge         Decimal   @default(0) @db.Decimal(12, 2)
  dChargeBasis    RateBasis @default(FIXED)
  stationery      Decimal   @default(0) @db.Decimal(12, 2)
  stationeryBasis RateBasis @default(FIXED)
  crossing        Decimal   @default(0) @db.Decimal(12, 2)
  crossingBasis   RateBasis @default(FIXED)

  @@unique([tenantId, partyId, productId, sourceCityId, destCityId])
  @@index([tenantId])
}

model DocumentType {
  id           String  @id @default(cuid())
  tenantId     String
  name         String
  description  String?
  showReminder Boolean @default(true)

  registrations VehicleDocument[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model VehicleDocument {
  id            String       @id @default(cuid())
  tenantId      String
  docNo         String?
  docTypeId     String
  docType       DocumentType @relation(fields: [docTypeId], references: [id])
  vehicleId     String
  companyName   String?
  status        String       @default("DONE") // DONE | PENDING
  entryDate     DateTime
  effectiveDate DateTime?
  expiryDate    DateTime?
  remarks       String?

  @@index([tenantId, expiryDate])
}

model JobHead {
  id           String  @id @default(cuid())
  tenantId     String
  name         String
  gstPct       Decimal @default(0) @db.Decimal(5, 2)
  hsnCode      String?
  description  String?
  showReminder Boolean @default(false)

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ============ LR / BOOKING ============

model Lr {
  id            String   @id @default(cuid())
  tenantId      String
  firmId        String
  fyId          String
  lrNo          String
  lrDate        DateTime
  refLrNo       String?
  privateMarka  String?
  isDummy       Boolean  @default(false)
  sourceCityId  String
  destCityId    String
  consignorId   String
  consigneeId   String
  billToId      String?
  vehicleId     String?
  vehicleText   String? // dummy LR free text
  ownerName     String?
  deliveryAt    String?
  transpMode    String?
  remarks       String?
  lrType        LrType   @default(TBB)
  status        LrStatus @default(PENDING)
  printFreight  Boolean  @default(true)
  gstApplicable Boolean  @default(false)

  // insurance
  insCompany  String?
  insPolicyNo String?
  insAmount   Decimal? @db.Decimal(14, 2)

  // party invoice / e-way
  invoiceNo   String?
  obdNo       String?
  refNo       String?
  invoiceDate DateTime?
  goodsValue  Decimal?  @db.Decimal(14, 2)
  ewayBillNo  String?
  ewayExpiry  DateTime?

  // charges
  freight     Decimal @default(0) @db.Decimal(14, 2)
  hamali      Decimal @default(0) @db.Decimal(12, 2)
  preBhada    Decimal @default(0) @db.Decimal(12, 2)
  biltyCharge Decimal @default(0) @db.Decimal(12, 2)
  collCharge  Decimal @default(0) @db.Decimal(12, 2)
  cpc         Decimal @default(0) @db.Decimal(12, 2)
  otherCharge Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @default(0) @db.Decimal(14, 2)
  cgstAmt     Decimal @default(0) @db.Decimal(12, 2)
  sgstAmt     Decimal @default(0) @db.Decimal(12, 2)
  igstAmt     Decimal @default(0) @db.Decimal(12, 2)
  advance     Decimal @default(0) @db.Decimal(14, 2)
  advanceBank String?
  grandTotal  Decimal @default(0) @db.Decimal(14, 2)

  // POD extras (filled at POD confirmation)
  poNumber    String?
  gateEntryNo String?

  items          LrItem[]
  chalanLrs      ChalanLr[]
  invoiceLrs     InvoiceLr[]
  pods           Pod[]
  trackingEvents TrackingEvent[]

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@unique([firmId, fyId, lrNo])
  @@index([tenantId, firmId, fyId, status])
  @@index([tenantId, vehicleId, status])
}

model LrItem {
  id           String    @id @default(cuid())
  tenantId     String
  lrId         String
  lr           Lr        @relation(fields: [lrId], references: [id], onDelete: Cascade)
  productId    String?
  productName  String
  description  String?
  qty          Decimal   @default(0) @db.Decimal(12, 3)
  actualWt     Decimal   @default(0) @db.Decimal(12, 3)
  chargeWt     Decimal   @default(0) @db.Decimal(12, 3)
  unit         String    @default("MT")
  rate         Decimal   @default(0) @db.Decimal(12, 2)
  rateBasis    RateBasis @default(CHARGE_WT)
  recWt        Decimal?  @db.Decimal(12, 3)
  shortageWt   Decimal?  @db.Decimal(12, 3)
  shortageRate Decimal?  @db.Decimal(12, 2)
  shortageAmt  Decimal?  @db.Decimal(12, 2)
  amount       Decimal   @default(0) @db.Decimal(14, 2)
  length       Decimal?  @db.Decimal(10, 2)
  width        Decimal?  @db.Decimal(10, 2)
  height       Decimal?  @db.Decimal(10, 2)

  @@index([tenantId])
}

// ============ CHALAN (freight challan to broker/owner) ============

model Chalan {
  id           String   @id @default(cuid())
  tenantId     String
  firmId       String
  fyId         String
  chalanNo     String
  chalanDate   DateTime
  brokerId     String
  vehicleId    String
  driverName   String?
  driverMobile String?
  licenseNo    String?
  payableAt    String?
  sourceCityId String?
  destCityId   String?
  remarks      String?

  actualWt       Decimal   @default(0) @db.Decimal(12, 3)
  chargeWt       Decimal   @default(0) @db.Decimal(12, 3)
  rate           Decimal   @default(0) @db.Decimal(12, 2)
  rateBasis      RateBasis @default(CHARGE_WT)
  freight        Decimal   @default(0) @db.Decimal(14, 2) // vehicle freight (manual)
  bookingFreight Decimal   @default(0) @db.Decimal(14, 2) // reference only, never printed
  detention      Decimal   @default(0) @db.Decimal(12, 2)
  odcAmt         Decimal   @default(0) @db.Decimal(12, 2)
  fineSlip       Decimal   @default(0) @db.Decimal(12, 2)
  ldCharge       Decimal   @default(0) @db.Decimal(12, 2)
  shortageAmt    Decimal   @default(0) @db.Decimal(12, 2)
  mamool         Decimal   @default(0) @db.Decimal(12, 2)
  courierCharge  Decimal   @default(0) @db.Decimal(12, 2)
  commissionPct  Decimal   @default(0) @db.Decimal(5, 2)
  commissionAmt  Decimal   @default(0) @db.Decimal(12, 2)
  tdsPct         Decimal   @default(0) @db.Decimal(5, 2)
  tdsAmt         Decimal   @default(0) @db.Decimal(12, 2)
  otherAmt       Decimal   @default(0) @db.Decimal(12, 2)
  otherRemarks   String?
  totalChalanAmt Decimal   @default(0) @db.Decimal(14, 2)
  grandTotal     Decimal   @default(0) @db.Decimal(14, 2)
  advanceTotal   Decimal   @default(0) @db.Decimal(14, 2)
  balance        Decimal   @default(0) @db.Decimal(14, 2)

  // trip KM
  startKm       Decimal?  @db.Decimal(12, 1)
  unloadDate    DateTime?
  unloadKm      Decimal?  @db.Decimal(12, 1)
  runningKm     Decimal?  @db.Decimal(12, 1)
  tripDays      Int?
  unloadRemarks String?

  isFinal Boolean @default(false)

  lrs      ChalanLr[]
  advances ChalanAdvance[]

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@unique([firmId, fyId, chalanNo])
  @@index([tenantId, firmId, fyId])
  @@index([tenantId, vehicleId])
}

model ChalanLr {
  id       String @id @default(cuid())
  tenantId String
  chalanId String
  chalan   Chalan @relation(fields: [chalanId], references: [id], onDelete: Cascade)
  lrId     String
  lr       Lr     @relation(fields: [lrId], references: [id])

  @@unique([chalanId, lrId])
  @@index([tenantId, lrId])
}

model ChalanAdvance {
  id           String      @id @default(cuid())
  tenantId     String
  chalanId     String
  chalan       Chalan      @relation(fields: [chalanId], references: [id], onDelete: Cascade)
  type         AdvanceType
  supplierName String?
  bankName     String?
  bankPartyId  String? // BANK-group party; posts to the bank book when set
  dieselQty    Decimal?    @db.Decimal(12, 3)
  dieselRate   Decimal?    @db.Decimal(12, 2)
  amount       Decimal     @default(0) @db.Decimal(14, 2)
  date         DateTime?
  remarks      String?

  @@index([tenantId])
}

// ============ PART-TRUCK OPS ============

model LoadingChalan {
  id           String            @id @default(cuid())
  tenantId     String
  firmId       String
  fyId         String
  chalanNo     String
  chalanDate   DateTime
  type         LoadingChalanType @default(DIRECT)
  vehicleId    String?
  driverName   String?
  driverMobile String?
  licenseNo    String?
  vehicleOwner String?
  brokerId     String?
  sourceCityId String?
  destCityId   String?
  remarks      String?
  lrIds        Json? // ordered list of LR ids on this loading chalan
  totFreight   Decimal           @default(0) @db.Decimal(14, 2)
  truckFreight Decimal           @default(0) @db.Decimal(14, 2)
  advance      Decimal           @default(0) @db.Decimal(14, 2)
  commAmt      Decimal           @default(0) @db.Decimal(12, 2)
  lcCharge     Decimal           @default(0) @db.Decimal(12, 2)
  dcCharge     Decimal           @default(0) @db.Decimal(12, 2)
  cfCharge     Decimal           @default(0) @db.Decimal(12, 2)
  totCrossing  Decimal           @default(0) @db.Decimal(12, 2)
  netAmount    Decimal           @default(0) @db.Decimal(14, 2)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([firmId, fyId, chalanNo])
  @@index([tenantId, firmId, fyId])
}

model Arrival {
  id         String   @id @default(cuid())
  tenantId   String
  firmId     String
  fyId       String
  arrivalNo  String
  unloadDate DateTime
  unloadedBy String?
  godownNo   String?
  manifestNo String?

  createdAt DateTime @default(now())

  @@unique([firmId, fyId, arrivalNo])
  @@index([tenantId])
}

model Delivery {
  id              String       @id @default(cuid())
  tenantId        String
  firmId          String
  fyId            String
  delNo           String
  delDate         DateTime
  type            DeliveryType @default(GATE_PASS)
  partyId         String?
  vehicleId       String?
  lrNo            String?
  grNo            String?
  freight         Decimal      @default(0) @db.Decimal(14, 2)
  totQty          Decimal      @default(0) @db.Decimal(12, 3)
  totWeight       Decimal      @default(0) @db.Decimal(12, 3)
  ewayBillNo      String?
  deliveryPerson  String?
  through         String?
  payType         LrType       @default(TO_PAY)
  cashType        CashCredit   @default(CASH)
  deliveryCharges Decimal      @default(0) @db.Decimal(12, 2)
  gatepassCharge  Decimal      @default(0) @db.Decimal(12, 2)
  labourCharges   Decimal      @default(0) @db.Decimal(12, 2)
  aoc             Decimal      @default(0) @db.Decimal(12, 2)
  damrage         Decimal      @default(0) @db.Decimal(12, 2)
  total           Decimal      @default(0) @db.Decimal(14, 2)
  remarks         String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([firmId, fyId, delNo])
  @@index([tenantId, firmId, fyId])
}

model Crossing {
  id            String    @id @default(cuid())
  tenantId      String
  firmId        String
  fyId          String
  chalanNo      String
  chalanDate    DateTime
  transporterId String?
  vehicleId     String?
  driverName    String?
  licenseNo     String?
  consigneeId   String?
  lrNo          String?
  grNo          String?
  sourceCityId  String?
  addressTo     String?
  freight       Decimal   @default(0) @db.Decimal(14, 2)
  ewayBillNo    String?
  payType       LrType    @default(TO_PAY)
  crossingAmt   Decimal   @default(0) @db.Decimal(14, 2)
  dcPct         Decimal   @default(0) @db.Decimal(5, 2)
  dcAmt         Decimal   @default(0) @db.Decimal(12, 2)
  toPayAmt      Decimal   @default(0) @db.Decimal(14, 2)
  paidAmt       Decimal   @default(0) @db.Decimal(14, 2)
  tbbAmt        Decimal   @default(0) @db.Decimal(14, 2)
  partA         Decimal   @default(0) @db.Decimal(14, 2)
  balance       Decimal   @default(0) @db.Decimal(14, 2)
  drCr          EntrySide @default(DEBIT)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([firmId, fyId, chalanNo])
  @@index([tenantId, firmId, fyId])
}

model OutwardCrossing {
  id              String    @id @default(cuid())
  tenantId        String
  firmId          String
  fyId            String
  ocNo            String
  chalanDate      DateTime
  arrivalNo       String?
  arrivalDate     DateTime?
  vehicleId       String?
  transporterId   String?
  sourceCityId    String?
  destCityId      String?
  lrType          LrType    @default(TO_PAY)
  unit            String?
  remarks         String?
  lines           Json // booking detail lines
  totalQty        Decimal   @default(0) @db.Decimal(12, 3)
